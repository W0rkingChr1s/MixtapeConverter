# Flask
SECRET_KEY=change-me-to-a-random-string

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback/spotify

# Apple Music (https://developer.apple.com)
APPLE_MUSIC_KEY_ID=your-key-id
APPLE_MUSIC_TEAM_ID=your-team-id
APPLE_MUSIC_PRIVATE_KEY_PATH=AuthKey_XXXXXXXX.p8

# Amazon Music (https://developer.amazon.com)
AMAZON_MUSIC_CLIENT_ID=your-client-id
AMAZON_MUSIC_CLIENT_SECRET=your-client-secret
AMAZON_MUSIC_REDIRECT_URI=http://localhost:5000/callback/amazon_music
